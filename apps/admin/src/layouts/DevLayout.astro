---
// 開発者専用ページ用レイアウト。上部にサブナビ（登録ユーザー / オンライン / 監査ログ）を持ち、
// 各タブは別ページ。nouker の DevLayout と同じ構成。
import BaseLayout from "@/layouts/BaseLayout.astro";

interface Props {
  title?: string;
}

const { title = "CredoBodyRise — 開発" } = Astro.props;
const pathname = Astro.url.pathname.replace(/\/$/, "");

const devNavItems = [
  { href: "/developer", label: "登録ユーザー" },
  { href: "/developer/online", label: "オンライン" },
  { href: "/developer/audit", label: "監査ログ" },
];
---

<BaseLayout title={title}>
  <div>
    <header class="border-b border-card-border bg-card-bg px-6 py-4">
      <h2 class="text-xl font-bold text-foreground">開発</h2>
      <p class="mt-0.5 text-[13px] text-muted">
        開発者専用機能（登録ユーザー・オンライン・監査ログ）
      </p>
      <nav class="mt-4 flex gap-1">
        {
          devNavItems.map((item) => {
            const isActive = pathname === item.href;
            const base =
              "px-4 py-2 rounded-lg text-[15px] font-medium transition-colors";
            const state = isActive
              ? "bg-accent text-white"
              : "text-foreground hover:bg-gray-100";
            return (
              <a href={item.href} class={`${base} ${state}`}>
                {item.label}
              </a>
            );
          })
        }
      </nav>
    </header>
    <div class="p-6">
      <slot />
    </div>
  </div>
</BaseLayout>
