---
import "@/styles/global.css";
import SidebarNav from "@/components/SidebarNav.astro";
import { SidebarUser } from "@/components/SidebarUser";
import { AuthCheck } from "@/components/AuthCheck";
import { PresenceTracker } from "@/components/PresenceTracker";
import { AutoUpdate } from "@/components/AutoUpdate";

interface Props {
  title?: string;
  requireAuth?: boolean;
}

const { title = "CredoBodyRise", requireAuth = true } = Astro.props;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="CredoBodyRise 管理画面（デスクトップ）" />
    <meta name="theme-color" content="#2563eb" />
    {/* ファビコン / アプリアイコン（Safari 等が確実に拾えるよう複数サイズを明示） */}
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192x192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/icon-512x512.png" />
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="CredoBodyRise 管理" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-180x180.png" />
    <link rel="apple-touch-icon" sizes="167x167" href="/apple-touch-icon-167x167.png" />
    <link rel="apple-touch-icon" sizes="152x152" href="/apple-touch-icon-152x152.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="apple-touch-icon-precomposed" href="/apple-touch-icon.png" />
  </head>
  <body class="flex h-full">
    {/* 新バージョン配信時に自動リロード（本番のみ）。認証有無に関わらず常駐。 */}
    <AutoUpdate client:only="react" />
    {
      requireAuth && (
        <>
          <AuthCheck client:only="react" />
          <PresenceTracker client:only="react" />
          <aside class="flex h-full w-56 shrink-0 flex-col border-r border-sidebar-border bg-sidebar-bg">
            <div class="border-b border-sidebar-border p-5">
              <h1 class="flex items-center gap-2 text-lg font-bold text-foreground">
                <img src="/icon.png" alt="" class="h-7 w-7 object-contain" />
                CredoBodyRise
                {/* 開発ビルド(astro dev)のみ LOCAL バッジ。本番では出力されない。 */}
                {import.meta.env.DEV && (
                  <span class="rounded bg-yellow-400 px-1.5 py-0.5 text-[11px] font-bold text-yellow-900">
                    LOCAL
                  </span>
                )}
              </h1>
            </div>
            <SidebarNav pathname={pathname} />
            <SidebarUser client:only="react" />
          </aside>
        </>
      )
    }
    <main class="flex-1 overflow-auto overscroll-contain">
      <slot />
    </main>
  </body>
</html>
