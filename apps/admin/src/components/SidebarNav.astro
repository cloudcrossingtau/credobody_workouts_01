---
// サイドバーのナビゲーション。今後 admin/developer 向け項目を足す場合は
// nouker と同様に adminOnly/developerOnly フラグ＋SidebarUser での表示制御で拡張する。
import { UnreadAnnouncementsBadge } from "@/components/UnreadAnnouncementsBadge";

interface NavItem {
  href: string;
  label: string;
  icon: string; // SVG path
  matchPaths?: string[];
  /// admin + developer に表示（初期は非表示、SidebarUser がロールに応じて開く）
  adminOnly?: boolean;
  /// developer のみ表示（初期は非表示、SidebarUser がロールに応じて開く）
  developerOnly?: boolean;
  /// true なら項目の右端に未読バッジを表示（お知らせ用）
  showUnreadBadge?: boolean;
}

const navItems: NavItem[] = [
  {
    href: "/",
    label: "ホーム",
    icon: "M3 9.5L12 3l9 6.5V21a1 1 0 0 1-1 1h-5v-7H9v7H4a1 1 0 0 1-1-1V9.5z",
  },
  {
    href: "/charts",
    label: "グラフ",
    icon: "M3 3v18h18M8 17v-4M13 17v-8M18 17v-6",
  },
  {
    href: "/announcements",
    label: "お知らせ",
    icon: "M11 5.882V19.24a1.76 1.76 0 0 1-3.417.585l-2.147-6.15M18 13a3 3 0 1 0 0-6M5.436 13.683A4.001 4.001 0 0 1 7 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 0 1-1.564-.317z",
    matchPaths: ["/announcements"],
    showUnreadBadge: true,
  },
  {
    href: "/settings",
    label: "設定",
    icon: "M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.28zM15 12a3 3 0 11-6 0 3 3 0 016 0z",
    matchPaths: ["/settings"],
  },
  {
    href: "/admin",
    label: "管理",
    icon: "M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z",
    matchPaths: ["/admin"],
    adminOnly: true,
  },
  {
    href: "/developer",
    label: "開発",
    icon: "M14.25 9.75L16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z",
    matchPaths: ["/developer"],
    developerOnly: true,
  },
];

interface Props {
  pathname: string;
}
const { pathname } = Astro.props;
---

<nav class="flex-1 p-3 space-y-1">
  {
    navItems.map((item) => {
      const isActive = item.matchPaths
        ? item.matchPaths.some((p) => pathname.startsWith(p))
        : pathname === item.href;
      const base =
        "flex items-center gap-3 px-3 py-2.5 rounded-lg text-[15px] font-medium transition-colors";
      const state = isActive
        ? "bg-accent-light text-accent"
        : "text-muted hover:bg-gray-100 hover:text-foreground";
      // adminOnly/developerOnly は初期非表示。SidebarUser がロール判定後に表示する。
      const roleAttrs = item.developerOnly
        ? { "data-developer-only": "" }
        : item.adminOnly
          ? { "data-admin-only": "" }
          : {};
      const initialStyle =
        item.developerOnly || item.adminOnly ? "display: none" : undefined;
      return (
        <a
          href={item.href}
          class={`${base} ${state}`}
          {...roleAttrs}
          style={initialStyle}
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d={item.icon}
            />
          </svg>
          {item.label}
          {item.showUnreadBadge && (
            <UnreadAnnouncementsBadge client:only="react" />
          )}
        </a>
      );
    })
  }
</nav>
