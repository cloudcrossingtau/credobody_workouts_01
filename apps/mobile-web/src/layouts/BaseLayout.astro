---
import "@/styles/global.css";
const { title = "トレーニング記録" } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <title>{title}</title>
    {/* アプリアイコン（暫定: CredoBody ロゴ。後で差し替え予定） */}
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />
    <meta name="apple-mobile-web-app-title" content="CredoBody" />
  </head>
  <body class="min-h-dvh bg-background text-foreground antialiased">
    <main class="mx-auto max-w-md px-4 pb-10">
      <slot />
    </main>
  </body>
</html>
